<?xml version="1.0" encoding="utf-8"?>
<plugin id="cordova-plugin-auto" version="1.0.0" xmlns="http://apache.org/cordova/ns/plugins/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
  <name>Android Auto Music Plugin</name>

  <engines>
      <engine name="cordova-android" version=">=12.0.0" />
  </engines>

  <js-module src="www/myplugin.js" name="auto">
      <clobbers target="cordova.plugins.auto" />
  </js-module>

  <platform name="android">
    <framework src="com.squareup.retrofit2:retrofit:3.0.0" />
    <framework src="com.squareup.retrofit2:converter-moshi:3.0.0" />
    <!-- <framework src="androidx.media:media:1.7.0" /> -->
    <framework src="com.squareup.moshi:moshi:1.15.2" />
    <framework src="com.squareup.moshi:moshi-kotlin:1.15.2" />
    <framework src="com.squareup.moshi:moshi-adapters:1.15.2" />
    <framework src="org.jetbrains.kotlinx:kotlinx-coroutines-core:1.9.0" />
    <framework src="com.squareup.okhttp3:okhttp:4.12.0" />
    <framework src="com.squareup.okhttp3:logging-interceptor:4.12.0" />

    <resource-file src="src/android/res/xml/automotive_app_desc.xml" target="res/xml/automotive_app_desc.xml" />
    <resource-file src="src/android/res/xml/allowed_media_browser_callers.xml" target="res/xml/allowed_media_browser_callers.xml" />
    <config-file target="res/xml/config.xml" parent="/*">
        <feature name="AndroidAutoPlugin">
            <param name="android-package" value="com.kuackmedia.androidauto.AndroidAutoPlugin" />
        </feature>
      <preference name="GradlePluginKotlinEnabled" value="true" />
      <preference name="GradlePluginKotlinCodeStyle"    value="official" />
      <preference name="GradlePluginKotlinVersion"      value="2.1.0" />
    </config-file>

    <config-file target="AndroidManifest.xml" parent="application">
      <service
              android:name="com.kuackmedia.androidauto.media.MusicLibraryService"
              android:exported="true"
              android:foregroundServiceType="mediaPlayback">
        <intent-filter>
          <action android:name="android.media.browse.MediaBrowserService"/>
        </intent-filter>
      </service>

      <meta-data
              android:name="com.google.android.gms.car.application"
        android:resource="@xml/automotive_app_desc" />

      <receiver android:enabled="true" android:exported="true" android:name="androidx.media.session.MediaButtonReceiver">
        <intent-filter>
          <action android:name="android.intent.action.MEDIA_BUTTON" />
        </intent-filter>
      </receiver>
    </config-file>

    <config-file target="AndroidManifest.xml" parent="/*">
      <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
      <uses-permission android:name="android.permission.INTERNET"/>
      <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
      <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
      <!-- Para que Android 11+ permita descubrir tu servicio -->
      <queries>
          <intent>
              <action android:name="android.media.browse.MediaBrowserService"/>
          </intent>
      </queries>
    </config-file>

    <source-file src="src/android/com/kuackmedia/androidauto/AndroidAutoPlugin.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto" />
    <source-file src="src/android/com/kuackmedia/androidauto/CordovaEventBridge.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto" />

    <source-file src="src/android/com/kuackmedia/androidauto/media/IPlayerAdapter.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />
    <source-file src="src/android/com/kuackmedia/androidauto/media/MediaPlayerAdapter.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />
    <source-file src="src/android/com/kuackmedia/androidauto/media/MediaSessionCallback.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />
