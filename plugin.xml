<?xml version="1.0" encoding="utf-8"?>
<plugin id="cordova-plugin-auto" version="1.0.0" xmlns="http://apache.org/cordova/ns/plugins/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
  <name>Android Auto Music Plugin</name>

  <engines>
      <engine name="cordova-android" version=">=12.0.0" />
      <engine name="cordova-ios" version=">=6.0.0" />
  </engines>

  <js-module src="www/myplugin.js" name="auto">
      <clobbers target="cordova.plugins.auto" />
  </js-module>

  <platform name="android">
    <framework src="com.squareup.retrofit2:retrofit:3.0.0" />
    <framework src="com.squareup.retrofit2:converter-moshi:3.0.0" />
    <!-- <framework src="androidx.media:media:1.7.0" /> -->
    <framework src="com.squareup.moshi:moshi:1.15.2" />
    <framework src="com.squareup.moshi:moshi-kotlin:1.15.2" />
    <framework src="com.squareup.moshi:moshi-adapters:1.15.2" />
    <framework src="org.jetbrains.kotlinx:kotlinx-coroutines-core:1.9.0" />
    <framework src="com.squareup.okhttp3:okhttp:4.12.0" />
    <framework src="com.squareup.okhttp3:logging-interceptor:4.12.0" />

    <resource-file src="src/android/res/xml/automotive_app_desc.xml" target="res/xml/automotive_app_desc.xml" />
    <resource-file src="src/android/res/xml/allowed_media_browser_callers.xml" target="res/xml/allowed_media_browser_callers.xml" />
    <config-file target="res/xml/config.xml" parent="/*">
        <feature name="AndroidAutoPlugin">
            <param name="android-package" value="com.kuackmedia.androidauto.AndroidAutoPlugin" />
        </feature>
      <preference name="GradlePluginKotlinEnabled" value="true" />
      <preference name="GradlePluginKotlinCodeStyle"    value="official" />
      <preference name="GradlePluginKotlinVersion"      value="2.1.0" />
    </config-file>

    <config-file target="AndroidManifest.xml" parent="application">
      <service
              android:name="com.kuackmedia.androidauto.media.MusicLibraryService"
              android:exported="true"
              android:foregroundServiceType="mediaPlayback">
        <intent-filter>
          <action android:name="android.media.browse.MediaBrowserService"/>
        </intent-filter>
      </service>

      <meta-data
              android:name="com.google.android.gms.car.application"
        android:resource="@xml/automotive_app_desc" />

      <receiver android:enabled="true" android:exported="true" android:name="androidx.media.session.MediaButtonReceiver">
        <intent-filter>
          <action android:name="android.intent.action.MEDIA_BUTTON" />
        </intent-filter>
      </receiver>
    </config-file>

    <config-file target="AndroidManifest.xml" parent="/*">
      <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
      <uses-permission android:name="android.permission.INTERNET"/>
      <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
      <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
      <!-- Para que Android 11+ permita descubrir tu servicio -->
      <queries>
          <intent>
              <action android:name="android.media.browse.MediaBrowserService"/>
          </intent>
      </queries>
    </config-file>

    <source-file src="src/android/com/kuackmedia/androidauto/AndroidAutoPlugin.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto" />
    <source-file src="src/android/com/kuackmedia/androidauto/CordovaEventBridge.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto" />

    <source-file src="src/android/com/kuackmedia/androidauto/media/IPlayerAdapter.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />
    <source-file src="src/android/com/kuackmedia/androidauto/media/MediaPlayerAdapter.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />
    <source-file src="src/android/com/kuackmedia/androidauto/media/MediaSessionCallback.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />
    <source-file src="src/android/com/kuackmedia/androidauto/media/MusicLibraryService.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />
    <source-file src="src/android/com/kuackmedia/androidauto/media/CurrentMedia.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />
    <source-file src="src/android/com/kuackmedia/androidauto/media/QueueManager.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />
    <source-file src="src/android/com/kuackmedia/androidauto/media/MediaControlBridge.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/media" />

    <source-file src="src/android/com/kuackmedia/androidauto/api/LocalAssetInterceptor.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/api" />
    <source-file src="src/android/com/kuackmedia/androidauto/api/MusicApi.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/api" />
    <source-file src="src/android/com/kuackmedia/androidauto/api/ServiceFactory.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/api" />
    <source-file src="src/android/com/kuackmedia/androidauto/api/TokenInterceptor.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/api" />

    <source-file src="src/android/com/kuackmedia/androidauto/tree/MediaItemTree.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/tree" />
    <source-file src="src/android/com/kuackmedia/androidauto/tree/MediaItemFactory.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/tree" />
    <source-file src="src/android/com/kuackmedia/androidauto/tree/MediaItemJsonAdapter.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/tree" />

    <source-file src="src/android/com/kuackmedia/androidauto/utils/LocalStorageUtils.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/utils" />
    <source-file src="src/android/com/kuackmedia/androidauto/utils/MediaUtils.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/utils" />

    <source-file src="src/android/com/kuackmedia/androidauto/models/AlbumItem.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/AlbumSummary.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/AlbumTracks.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/ArtistTracks.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/Artist.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/CoverImage.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/Curator.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/HistoryResponse.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/ImageColorInfo.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/MediaItem.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/NavigationData.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/PingResponse.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/PlayListItem.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/PlayListTrack.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/Tag.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/Track.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/User.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/EmptyModel.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/RecentListened.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/AutoNavigationExplorer.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/TrackAPIModels.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/QueueItem.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/SearchResponse.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />
    <source-file src="src/android/com/kuackmedia/androidauto/models/TagTracksResponse.kt" target-dir="app/src/main/kotlin/com/kuackmedia/androidauto/models" />

  </platform>

  <platform name="ios">
    <config-file target="config.xml" parent="/*">
      <feature name="AutoMusicPlugin">
        <param name="ios-package" value="CDVAutoMusicPlugin" />
        <param name="onload" value="true" />
      </feature>
    </config-file>

    <!-- CarPlay entitlement and Info.plist configuration -->
    <config-file target="*-Info.plist" parent="UIBackgroundModes">
      <array>
        <string>audio</string>
      </array>
    </config-file>

    <config-file target="*-Info.plist" parent="NSAppleMusicUsageDescription">
      <string>This app needs access to Apple Music to play your music in CarPlay.</string>
    </config-file>

    <!-- CarPlay app configuration -->
    <config-file target="*-Info.plist" parent="UIApplicationSceneManifest">
      <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <true/>
        <key>UISceneConfigurations</key>
        <dict>
          <!-- Main application window scene -->
          <key>UIWindowSceneSessionRoleApplication</key>
          <array>
            <dict>
              <key>UISceneConfigurationName</key>
              <string>Default Configuration</string>
              <key>UISceneClassName</key>
              <string>UIWindowScene</string>
              <key>UISceneDelegateClassName</key>
              <string>SceneDelegate</string>
            </dict>
          </array>

          <!-- CarPlay template scene -->
          <key>CPTemplateApplicationSceneSessionRoleApplication</key>
          <array>
            <dict>
              <key>UISceneConfigurationName</key>
              <string>CarPlay Configuration</string>
              <key>UISceneClassName</key>
              <string>CPTemplateApplicationScene</string>
              <key>UISceneDelegateClassName</key>
              <string>CDVCarPlaySceneDelegate</string>
            </dict>
          </array>
        </dict>
      </dict>
    </config-file>

    <config-file target="*-Info.plist" parent="com.apple.developer.carplay-audio">
      <true/>
    </config-file>

    <!-- Source files -->
    <header-file src="src/ios/CDVAutoMusicPlugin.h" />
    <source-file src="src/ios/CDVAutoMusicPlugin.m" />
    <header-file src="src/ios/CDVCarPlaySceneDelegate.h" />
    <source-file src="src/ios/CDVCarPlaySceneDelegate.m" />
    <header-file src="src/ios/CDVCarPlayManager.h" />
    <source-file src="src/ios/CDVCarPlayManager.m" />
    <header-file src="src/ios/CDVMusicPlayer.h" />
    <source-file src="src/ios/CDVMusicPlayer.m" />
    <header-file src="src/ios/CDVPlaylistProvider.h" />
    <source-file src="src/ios/CDVPlaylistProvider.m" />
    <header-file src="src/ios/SceneDelegate.h" />
    <source-file src="src/ios/SceneDelegate.m" />
    
    <!-- CPNowPlayingTemplate extension category -->
    <header-file src="src/ios/CPNowPlayingTemplate+CDVExtensions.h" />
    <source-file src="src/ios/CPNowPlayingTemplate+CDVExtensions.m" />

    <framework src="MediaPlayer.framework" />
    <framework src="CarPlay.framework" weak="true" />
  </platform>
</plugin>
